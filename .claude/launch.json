{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web (Vite React UI)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev"],
      "port": 5173
    },
    {
      "name": "website (Docusaurus docs)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "website", "run", "start"],
      "port": 3000
    },
    {
      "name": "desktop renderer (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "apps/desktop", "run", "dev:renderer"],
      "port": 5174
    },
    {
      "name": "hermes gateway (dashboard)",
      "runtimeExecutable": "hermes",
      "runtimeArgs": ["gateway"],
      "port": 9119
    }
  ]
}
